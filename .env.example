POSTGRES_DB=schule
POSTGRES_USER=schule
POSTGRES_PASSWORD=HIER_EIN_LANGES_ZUFAELLIGES_PASSWORT_EINTRAGEN
DJANGO_SECRET_KEY=HIER_EINEN_LANGEN_ZUFAELLIGEN_SECRET_KEY_EINTRAGEN
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,schule.plebsapps.de
DJANGO_CSRF_TRUSTED_ORIGINS=https://schule.plebsapps.de
DJANGO_SECURE_COOKIES=false
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_SESSION_COOKIE_AGE=1800
DJANGO_LOGIN_FAILURE_LIMIT=5
DJANGO_LOG_LEVEL=INFO
BACKUP_DIR=backups/postgres
BACKUP_RETENTION_DAYS=30
